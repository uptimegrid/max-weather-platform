# Copy to backend.hcl and fill with the values printed by scripts/bootstrap-backend.sh.
# Then run: terraform init -backend-config=backend.hcl
# State locking uses S3 native locking (use_lockfile = true in backend.tf); no
# DynamoDB table is required.
bucket = "mw-apse1-tfstate-REPLACE-WITH-ACCOUNT-ID-01"
region = "ap-southeast-1"
