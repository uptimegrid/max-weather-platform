          <mxGeometry x="40" y="150" width="1580" height="980" as="geometry" />
        </mxCell>

        <!-- Managed services -->
        <mxCell id="apigw" value="AWS API Gateway (HTTP API)&#10;- ONLY public entry point&#10;- JWT authorizer (Cognito)&#10;- VPC Link -&gt; internal NLB&#10;- access logs -&gt; CloudWatch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="600" y="190" width="280" height="120" as="geometry" />
        </mxCell>
        <mxCell id="cognito" value="Amazon Cognito&#10;OAuth2 authorization server&#10;user pool / resource server / app client" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6" vertex="1" parent="1">
