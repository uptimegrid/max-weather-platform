<mxfile host="app.diagrams.net" type="device">
  <diagram id="arch-main" name="Architecture">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===================== Internet zone ===================== -->
        <mxCell id="client" value="Client / Postman&#10;(HTTPS + Bearer JWT)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="700" y="40" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="github" value="GitHub&#10;(source repos)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1" vertex="1" parent="1">
