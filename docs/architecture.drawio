        </mxCell>
        <mxCell id="weatherapi" value="External weather provider&#10;(Open-Meteo geocoding / forecast)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1380" y="40" width="220" height="70" as="geometry" />
        </mxCell>

        <!-- ===================== AWS Cloud boundary ===================== -->
